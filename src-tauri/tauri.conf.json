{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apple Container Desktop",
  "version": "0.2.0",
  "identifier": "com.boostbrothers.apple-container-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apple Container Desktop",
        "width": 800,
        "height": 600,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxQkRDREMxNTZGODUyMTIKUldRU1V2aFd3YzI5c1hoMitVUG1GUlZKRnk4NDhtRmpKSW4yd1AvR0J2cVhYMFpISGdYOGx5ajYK",
      "endpoints": [
        "https://github.com/boostbrothers/apple-container-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
